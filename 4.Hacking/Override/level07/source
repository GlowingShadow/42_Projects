#include <...>


unsigned int	get_unum(void)
{
	fflush(stdin);
	unsigned int n;
	scanf(stdin, "%u", &n);
	clear_stdin();
	return n;
}

int		store_number(unsigned int *tab)
{
	printf(" Number: ");
	unsigned int number = get_unum();
	printf(" Index: ");
	unsigned int index = get_unum();
	if (index % 3 == 0)
	{
		puts(" *** ERROR! ***");
		puts("   This index is reserved for wil!");
		puts(" *** ERROR! ***");
		return 1;
	}

	tab[index] = number;

	return 0;
}

int		read_number(unsigned int *tab)
{
	printf(" Index: ");
	unsigned int index = get_unum();
	printf(" Number at data[%u] is %u\n", index, tab[index]);
	return 0;
}

